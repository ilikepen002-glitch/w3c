public function tdTowerBaseSkillIconPath(int towerChoice) returns string
	if towerChoice == TD_TOWER_CHOICE_ARCHER
		return Icons.bTNSearingArrows
	if towerChoice == TD_TOWER_CHOICE_ORC
		return Icons.bTNCriticalStrike
	if towerChoice == TD_TOWER_CHOICE_FOOTMAN
		return Icons.bTNBash
	if towerChoice == TD_TOWER_CHOICE_DRYAD
		return Icons.bTNSlowPoison
	if towerChoice == TD_TOWER_CHOICE_GHOUL
		return Icons.bTNUnholyFrenzy
	return ""

public function tdTowerSupportSkillIconPath(int towerChoice) returns string
	if towerChoice == TD_TOWER_CHOICE_ARCHER
		return tdArcherAuraIconPath()
	if towerChoice == TD_TOWER_CHOICE_ORC
		return tdOrcBladestormIconPath()
	if towerChoice == TD_TOWER_CHOICE_FOOTMAN
		return Icons.bTNCommand
	if towerChoice == TD_TOWER_CHOICE_DRYAD
		return Icons.bTNEntanglingRoots
	if towerChoice == TD_TOWER_CHOICE_GHOUL
		return Icons.bTNCorpseExplode
	return ""

public function tdTowerPerfectSkillIconPath(int towerChoice) returns string
	if towerChoice == TD_TOWER_CHOICE_ARCHER
		return tdArcherPerfectAuraIconPath()
	if towerChoice == TD_TOWER_CHOICE_ORC
		return Icons.bTNBattleRoar
	if towerChoice == TD_TOWER_CHOICE_FOOTMAN
		return Icons.bTNStormHammer
	if towerChoice == TD_TOWER_CHOICE_DRYAD
		return Icons.bTNPoisonSting
	if towerChoice == TD_TOWER_CHOICE_GHOUL
		return Icons.bTNBerserk
	return ""

public function tdArcherSplitArrowTargetCount(int level) returns int
	if level < 1
		return 0
	var clampedLevel = level
	if level > TD_MAX_TOWER_LEVEL
		clampedLevel = TD_MAX_TOWER_LEVEL
	return clampedLevel + 1

public function tdArcherHasSplitArrowAtLevelBranch(int level, int branch) returns boolean
	if level < 1
		return false
	if level < TD_MAX_TOWER_LEVEL
		return true
	return branch == TD_TOWER_BRANCH_A

