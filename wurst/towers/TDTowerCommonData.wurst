public function tdBonusPercentString(real bonus) returns string
	return (bonus * 100.0 + 0.5).toInt().toString() + "%"

public function tdSlowPercentString(real remainingFactor) returns string
	return ((1.0 - remainingFactor) * 100.0 + 0.5).toInt().toString() + "%"
