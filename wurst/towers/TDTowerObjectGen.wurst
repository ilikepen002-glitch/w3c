package TDTowerObjectGen
import TDConfig
import TDTowerData
import TDItemData
import ChannelAbilityPreset

function BuildingDefinition.tdApplyTowerBuildingStats(int towerChoice, int level, int branch, string abilities) returns BuildingDefinition
	this
	..setName(tdTowerDisplayNameForBranch(towerChoice, level, branch))
	..setTooltipBasic(tdTowerDisplayNameForBranch(towerChoice, level, branch))
	..setTooltipExtended(tdTowerTooltipExtendedForBranch(towerChoice, level, branch))
	..setDescription(tdTowerLoreForBranch(towerChoice, level, branch))
	..setHitPointsMaximumBase(tdTowerBaseHitPointsForBranch(towerChoice, level, branch))
	..setDefenseBase(tdTowerBaseArmorForBranch(towerChoice, level, branch))
	..setAttack1DamageBase(tdTowerBaseDamageForBranch(towerChoice, level, branch))
	..setAttack1DamageNumberofDice(1)
	..setAttack1DamageSidesperDie(6 + level)
	..setAttack1CooldownTime(tdTowerBaseCooldownForBranch(towerChoice, level, branch))
	..setAttack1Range(tdTowerObjectAttackRangeForBranch(towerChoice, level, branch))
	..setAttack1RangeMotionBuffer(tdTowerAttackRangeMotionBuffer())
	..setAttacksEnabled(1)
	..setAttack1AttackType(tdTowerAttackType(towerChoice))
	..setAttack1WeaponType(tdTowerWeaponType(towerChoice))
	..setAttack1ProjectileArt(tdTowerProjectileArt(towerChoice))
	..setAttack1ProjectileSpeed(tdTowerProjectileSpeed(towerChoice))
	..setAttack1ProjectileHomingEnabled(tdTowerWeaponType(towerChoice) == WeaponType.Missile)
	..setModelFile(tdTowerModelPath(towerChoice, level))
	..setMovementType(MovementType.None)
	..setSpeedBase(0)
	..setSpeedMinimum(0)
	..setSpeedMaximum(0)
	..setCanFlee(false)
	..setCollisionSize(tdTowerCollisionSize())
	..setPathingMap(tdTowerPathingMap())
	..setAcquisitionRange(tdTowerAcquisitionRangeForBranch(towerChoice, level, branch))
	..setAttack1TargetsAllowed("enemy,ground,air,organic")
	..setGoldCost(tdTowerGoldCostForLevelBranch(towerChoice, level, branch))
	..setLumberCost(0)
	..setFoodCost(tdTowerFoodCostForObjectGen())
	..setFoodProduced(0)
	..setBuildTime(2 + level)
	..setRepairGoldCost(0)
	..setRepairLumberCost(0)
	..setRequirements(tdTowerRequirementsRawcodes(towerChoice, level))
	..setRequirementsLevels(tdTowerRequirementsLevelsRawcodes(towerChoice, level))
	..setDependencyEquivalents(tdTowerDependencyEquivalentsRawcodes(towerChoice, level))
	..setUpgradesUsed(tdTowerUpgradesUsedRawcodes(towerChoice, level))
	..setRace(tdTowerRaceForObjectGen())
	..setPlacementRequires(tdTowerPlacementRequires())
	..setPlacementPreventedBy(tdTowerPlacementPreventedBy())
	..setUnitsTrained("")
	..setResearchesAvailable("")
	..setItemsMade("")
	..setGroundTexture(tdTowerGroundTexture())
	..setNormalAbilities(abilities + "," + TD_TOWER_INVENTORY_ABILITY_ID.toRawCode())
	..setIconGameInterface(tdTowerIconPath(towerChoice))
	..setIconScoreScreen(tdTowerIconPath(towerChoice))
	..setPointValue(40 + level * 10)
	..setSelectionScale(tdTowerSelectionScale(towerChoice, level))
	..setSelectionCircleOnWater(true)
	..setScalingValue(0.95 + level * 0.03)
	..setButtonPositionX(tdTowerLevelButtonX(towerChoice, level, branch))
	..setButtonPositionY(tdTowerLevelButtonY(towerChoice, level, branch))
	..setHotkey(tdTowerHotkey(towerChoice))
	return this

// 这些 compiletime 定义会直接生成最终地图里的物编数据，
// 也就是把塔的平衡和技能配置放在代码里维护，而不是靠手改 WE。
@compiletime function tdGenerateTowerAbilities()
	new AbilityDefinitionMoonPriestessTrueshotAura(TD_ARCHER_TRUESHOT_ABILITY_ID)
	..setName("白虎战吼")
	..setTooltipNormal(1, "白虎战吼")
	..setTooltipNormalExtended(1, "被动：为周围友军提供" + tdBonusPercentString(tdArcherAuraDamageBonus()) + "攻击力加成。")
	..setIconResearch(tdArcherAuraIconPath())
	..setIconNormal(tdArcherAuraIconPath())
	..setButtonPositionNormalX(1)
	..setButtonPositionNormalY(1)
	..setDamageBonus(1, tdArcherAuraDamageBonus())
	..setRangedBonus(1, true)
	..setMeleeBonus(1, true)
	..setFlatBonus(1, false)
	..setTargetsAllowed(1, tdTowerAuraTargetsAllowed())
	..setHeroAbility(false)
	..setItemAbility(false)
	..setRequirements("")
	..setRequirementsLevels("")
	..setCheckDependencies(false)

	new AbilityDefinitionBladeMasterCriticalStrike(TD_ARCHER_SPLIT_ARROW_ABILITY_ID)
	..setName("分裂箭")
	..setTooltipNormal(1, "分裂箭")
	..setTooltipNormalExtended(1, "普通攻击会同时射向多个目标。1级总计2个目标，每升1级额外+1个目标，5级总计6个目标。")
	..setIconResearch(tdTowerBaseSkillIconPath(TD_TOWER_CHOICE_ARCHER))
	..setIconNormal(tdTowerBaseSkillIconPath(TD_TOWER_CHOICE_ARCHER))
	..setButtonPositionNormalX(0)
	..setButtonPositionNormalY(1)
	..setChancetoCriticalStrike(1, 0.0)
	..setDamageMultiplier(1, 1.0)
	..setDamageBonus(1, 0.0)
	..setNeverMiss(1, false)
	..setHeroAbility(false)
	..setItemAbility(false)
	..setRequirements("")
	..setRequirementsLevels("")
	..setCheckDependencies(false)

	new AbilityDefinitionBladeMasterCriticalStrike(TD_ORC_CRIT_ABILITY_ID)
	..setName("致命一击")
	..setTooltipNormal(1, "致命一击")
	..setTooltipNormalExtended(1, "被动：有" + tdBonusPercentString(tdOrcCriticalStrikeChance()) + "概率造成" + tdOrcCriticalStrikeMultiplier().toString() + "倍伤害，并额外附加" + tdOrcCriticalStrikeDamageBonus().toInt().toString() + "点伤害。")
	..presetIcon(tdTowerBaseSkillIconPath(TD_TOWER_CHOICE_ORC))
	..presetButtonPosNormal(0, 1)
	..setChancetoCriticalStrike(1, tdOrcCriticalStrikeChance())
	..setDamageMultiplier(1, tdOrcCriticalStrikeMultiplier())
	..setDamageBonus(1, tdOrcCriticalStrikeDamageBonus())
	..setNeverMiss(1, true)
	..setHeroAbility(false)
	..setItemAbility(false)
	..setRequirements("")
	..setRequirementsLevels("")
	..setCheckDependencies(false)

	new AbilityDefinitionPitLordCleavingAttack(TD_ORC_CLEAVE_ABILITY_ID)
	..setName("剑刃风暴")
	..setTooltipNormal(1, "剑刃风暴")
	..setTooltipNormalExtended(1, "被动：普通攻击对目标周围单位造成" + tdBonusPercentString(tdOrcCleaveFactor()) + "溅射伤害。")
	..presetIcon(tdTowerSupportSkillIconPath(TD_TOWER_CHOICE_ORC))
