	..setDistributedDamageFactor(1, tdOrcCleaveFactor())
	..setHeroAbility(false)
	..setItemAbility(false)
	..setRequirements("")
	..setRequirementsLevels("")
	..setCheckDependencies(false)

	new AbilityDefinitionMountainKingBash(TD_FOOT_BASH_ABILITY_ID)
