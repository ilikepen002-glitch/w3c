	..setTooltipNormal(1, "盾击")
	..setTooltipNormalExtended(1, "被动：有" + tdBonusPercentString(tdFootmanBashChance()) + "概率打出盾击，造成额外" + tdFootmanBashDamageBonus().toInt().toString() + "点伤害。")
	..presetIcon(tdTowerBaseSkillIconPath(TD_TOWER_CHOICE_FOOTMAN))
	..presetButtonPosNormal(0, 1)
