	..makeUnitSpell(0, 0.0)
	..setCheckDependencies(false)

// 在编译期生成农民单位对应的物编数据，
// 这样地图就不依赖于编辑器里手工做好的自定义单位。
@compiletime function tdGenerateBuilderObjects()
	new UnitDefinition(TD_FARMER_UNIT_ID, 'hpea')
	..setName("TD农民")
	..setTooltipBasic("TD农民")
	..setTooltipExtended("空中建造工人，可穿越障碍并用闪烁快速移动到建造位。")
	..setDescription("TD工人")
	..setNormalAbilities("AHbu,Ahrp," + TD_FARMER_BLINK_ABILITY_ID.toRawCode() + "," + TD_FARMER_WAGE_ABILITY_ID.toRawCode() + "," + TD_FARMER_INVENTORY_ABILITY_ID.toRawCode() + "," + TD_FARMER_CRAFT_ABILITY_ID.toRawCode())
	..setStructuresBuilt(tdFarmerBuildMenuRawcodes())
	..setGoldCost(0)
	..setLumberCost(0)
	..setFoodCost(tdFarmerFoodCostForObjectGen())
	..setFoodProduced(0)
	..setAttacksEnabled(0)
	..setAcquisitionRange(0)
	..setCanFlee(false)
	..setMovementType(MovementType.Fly)
	..setMovementHeight(275.0)
	..setMovementHeightMinimum(275.0)
	..setSpeedBase(tdFarmerBaseMoveSpeed())
	..setSpeedMinimum(tdFarmerBaseMoveSpeed())
	..setSpeedMaximum(tdFarmerBaseMoveSpeed())
	..setHotkey("B")

function tdGenerateTowerLevelObject(int towerChoice, int level, int branch)
	let definition = new BuildingDefinition(tdTowerUnitIdForLevelBranch(towerChoice, level, branch), tdTowerObjectParentId(towerChoice, level))
	definition
	..tdApplyTowerBuildingStats(towerChoice, level, branch, tdTowerNormalAbilitiesRawcodesForBranch(towerChoice, level, branch))
	if tdCanUpgradeTowerLevel(towerChoice, level)
		definition.setUpgradesTo(tdTowerUpgradeRawcode(towerChoice, level))

function tdGenerateTowerFamilyObjects(int towerChoice)
	for level = 1 to 5
		tdGenerateTowerLevelObject(towerChoice, level, TD_TOWER_BRANCH_A)
	tdGenerateTowerLevelObject(towerChoice, 6, TD_TOWER_BRANCH_A)
	tdGenerateTowerLevelObject(towerChoice, 6, TD_TOWER_BRANCH_B)

// 在编译期根据代码里的数值批量生成所有塔的等级和升级链。
@compiletime function tdGenerateTowerObjects()
	for towerChoice = 1 to TD_TOWER_CHOICE_COUNT
		tdGenerateTowerFamilyObjects(towerChoice)
