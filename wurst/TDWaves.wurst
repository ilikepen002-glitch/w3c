public function tdWaveBossGuardEnemyCount(int wave) returns int
	if wave == 8 or wave == 16
		return 1
	if wave == 24 or wave == 32
		return 2
	return 0

public function tdWaveBossEnemyCount(int wave) returns int
	if wave == 8 or wave == 16 or wave == 24 or wave == 32
		return 1
	return 0

function tdWaveSpecialEnemyCount(int wave) returns int
	return tdWaveEliteEnemyCount(wave) + tdWaveBossGuardEnemyCount(wave) + tdWaveBossEnemyCount(wave)

public function tdWaveEnemyCount(int wave) returns int
	return tdWaveNormalEnemyCount(wave) + tdWaveSpecialEnemyCount(wave)

