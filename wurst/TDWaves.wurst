	if wave == 9
		return 0.72
	if wave == 10
		return 0.64
	if wave == 11
		return 0.78
	if wave == 12
		return 0.76
	if wave == 13
		return 0.62
	if wave == 14
		return 0.74
	if wave == 15
		return 0.68
	return 0.60

