constant int TD_WAVE_15_ELITE_UNIT_ID = 'uS15'
constant int TD_WAVE_16_BOSS_UNIT_ID = 'uB16'

function tdScaledEnemyStat(int baseValue, real multiplier) returns int
	if baseValue <= 0
		return 0
	return R2I(baseValue * multiplier + 0.5)

function tdScaledEconomyValue(int baseValue) returns int
	return tdScaledEnemyStat(baseValue, tdEconomyMultiplier())

public function tdEnemySleepsAtNight() returns boolean
	return false

public function tdEnemyNativeGoldBountyBase() returns int
	return 0

public function tdEnemyNativeGoldBountyDice() returns int
	return 0

public function tdEnemyNativeGoldBountySides() returns int
	return 0

function UnitDefinition.tdApplyEscaperStats(string name, int hitPoints, int armor, int speed) returns UnitDefinition
	this
	..setName(name)
	..setDescription("只会沿路逃跑，不会反击。")
	..setHitPointsMaximumBase(hitPoints)
	..setDefenseBase(armor)
	..setSpeedBase(speed)
	..setSpeedMinimum(speed)
	..setSpeedMaximum(speed)
	..setAttacksEnabled(0)
	..setAcquisitionRange(0)
	..setCanFlee(false)
	..setSleeps(tdEnemySleepsAtNight())
	..setGoldBountyAwardedBase(tdEnemyNativeGoldBountyBase())
	..setGoldBountyAwardedNumberofDice(tdEnemyNativeGoldBountyDice())
	..setGoldBountyAwardedSidesperDie(tdEnemyNativeGoldBountySides())
	..setLumberBountyAwardedBase(0)
	..setLumberBountyAwardedNumberofDice(0)
	..setLumberBountyAwardedSidesperDie(0)
	..setCollisionSize(12)
	..setPointValue(20)
	return this

function tdWaveNormalName(int wave) returns string
	if wave == 1
		return "教学杂兵"
	if wave == 2
		return "学徒步卒"
	if wave == 3
		return "数量施压者"
	if wave == 4
		return "铁盾杂兵"
	if wave == 5
		return "疾行掠夺者"
	if wave == 6
		return "厚皮蛮兵"
	if wave == 7
		return "护甲卫兵"
	if wave == 8
		return "检定步卒"
	if wave == 9
		return "回压战群"
	if wave == 10
		return "夜刃快袭者"
	if wave == 11
		return "厚血重兵"
	if wave == 12
		return "双压战团"
	if wave == 13
		return "混编攻城者"
	if wave == 14
		return "重甲卫队"
	if wave == 15
		return "决战先遣队"
	return "Boss护卫"

function tdWaveSpecialName(int wave) returns string
	if wave == 8
		return "阶段精英"
	if wave == 12
		return "双生精英"
	if wave == 15
		return "决战精英"
	return "中路统领"

public function tdWaveCount() returns int
	return 16

