	return 1.00

function tdWaveNormalName(int wave) returns string
	if wave == 4
		return "精英护卫"
	if wave == 8
		return "早期Boss护卫"
	if wave == 16
		return "中期Boss护卫"
	if wave == 24
		return "后期Boss护卫"
	if wave == 32
		return "终局Boss护卫"
	return "第" + wave.toString() + "波逃兵"

