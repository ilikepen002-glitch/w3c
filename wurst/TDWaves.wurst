public function tdWaveEliteEnemyCount(int wave) returns int
	if wave == 8
		return 1
	if wave == 12
		return 2
	if wave == 15
		return 3
	return 0

public function tdWaveBossEnemyCount(int wave) returns int
	if wave == 16
		return 1
	return 0

public function tdIsEliteUnitTypeId(int unitTypeId) returns boolean
	return unitTypeId == TD_WAVE_8_ELITE_UNIT_ID or unitTypeId == TD_WAVE_12_ELITE_UNIT_ID or unitTypeId == TD_WAVE_15_ELITE_UNIT_ID

public function tdIsBossUnitTypeId(int unitTypeId) returns boolean
	return unitTypeId == TD_WAVE_16_BOSS_UNIT_ID

function tdWaveSpecialEnemyCount(int wave) returns int
	return tdWaveEliteEnemyCount(wave) + tdWaveBossEnemyCount(wave)

public function tdWaveEnemyCount(int wave) returns int
	return tdWaveNormalEnemyCount(wave) + tdWaveSpecialEnemyCount(wave)

