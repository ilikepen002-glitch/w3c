public function tdWaveKillGold(int wave) returns int
	if wave <= 3
		return tdScaledEconomyValue(3)
	if wave <= 7
		return tdScaledEconomyValue(4)
	if wave <= 15
		return tdScaledEconomyValue(5)
	if wave <= 16
		return tdScaledEconomyValue(6)
	if wave <= 20
		return tdScaledEconomyValue(7)
	if wave <= 24
		return tdScaledEconomyValue(8)
	if wave <= 28
		return tdScaledEconomyValue(9)
	return tdScaledEconomyValue(10)

public function tdWaveScoreValue(int wave) returns int
	if wave <= 0
		return 0
	return 1 + wave * 2 + tdWaveEliteEnemyCount(wave) * 3 + tdWaveBossGuardEnemyCount(wave) * 4 + tdWaveBossEnemyCount(wave) * 8

function tdWaveObjectParentId(int wave) returns int
	if wave == 1
		return 'hpea'
	if wave == 2
		return 'hfoo'
	if wave == 3
		return 'ugho'
	if wave == 4
		return 'hrif'
	if wave == 5
		return 'ogru'
	if wave == 6
		return 'edry'
	if wave == 7
		return 'esen'
	if wave == 8
		return 'uaco'
	if wave == 9
		return 'okod'
	if wave == 10
		return 'nfel'
	if wave == 11
		return 'otau'
	if wave == 12
		return 'uabo'
	if wave == 13
		return 'ncen'
	if wave == 14
		return 'hkni'
	if wave == 15
		return 'nbal'
	if wave == 16
		return 'opeo'
	if wave <= 20
		return 'nmyr'
	if wave <= 24
		return 'nsgu'
	if wave <= 28
		return 'nfod'
	return 'nrvd'

@compiletime function tdGenerateEscaperObjects()
	for wave = 1 to tdWaveCount()
		new UnitDefinition(tdWaveUnitId(wave), tdWaveObjectParentId(wave))
		..tdApplyEscaperStats(tdWaveNormalName(wave), tdWaveBaseHitPoints(wave), tdWaveBaseArmor(wave), tdWaveBaseSpeed(wave))

	new UnitDefinition(TD_WAVE_4_ELITE_UNIT_ID, 'nfel')
	..tdApplyEscaperStats(tdWaveEliteName(4), tdWaveEliteHitPoints(4), tdWaveEliteArmor(4), tdWaveEliteSpeed(4))
	new UnitDefinition(TD_WAVE_12_ELITE_UNIT_ID, 'nbst')
	..tdApplyEscaperStats(tdWaveEliteName(12), tdWaveEliteHitPoints(12), tdWaveEliteArmor(12), tdWaveEliteSpeed(12))
	new UnitDefinition(TD_WAVE_20_ELITE_UNIT_ID, 'ordr')
	..tdApplyEscaperStats(tdWaveEliteName(20), tdWaveEliteHitPoints(20), tdWaveEliteArmor(20), tdWaveEliteSpeed(20))
	new UnitDefinition(TD_WAVE_28_ELITE_UNIT_ID, 'nbal')
	..tdApplyEscaperStats(tdWaveEliteName(28), tdWaveEliteHitPoints(28), tdWaveEliteArmor(28), tdWaveEliteSpeed(28))

	new UnitDefinition(TD_WAVE_8_GUARD_UNIT_ID, 'nmyr')
	..tdApplyEscaperStats(tdWaveBossGuardName(8), tdWaveBossGuardHitPoints(8), tdWaveBossGuardArmor(8), tdWaveBossGuardSpeed(8))
	new UnitDefinition(TD_WAVE_16_GUARD_UNIT_ID, 'nsgu')
	..tdApplyEscaperStats(tdWaveBossGuardName(16), tdWaveBossGuardHitPoints(16), tdWaveBossGuardArmor(16), tdWaveBossGuardSpeed(16))
	new UnitDefinition(TD_WAVE_24_GUARD_UNIT_ID, 'nfod')
	..tdApplyEscaperStats(tdWaveBossGuardName(24), tdWaveBossGuardHitPoints(24), tdWaveBossGuardArmor(24), tdWaveBossGuardSpeed(24))
	new UnitDefinition(TD_WAVE_32_GUARD_UNIT_ID, 'nrvd')
	..tdApplyEscaperStats(tdWaveBossGuardName(32), tdWaveBossGuardHitPoints(32), tdWaveBossGuardArmor(32), tdWaveBossGuardSpeed(32))

	new UnitDefinition(TD_WAVE_8_BOSS_UNIT_ID, 'Ocbh')
	..tdApplyEscaperStats(tdWaveBossName(8), tdWaveBossHitPoints(8), tdWaveBossArmor(8), tdWaveBossSpeed(8))
	new UnitDefinition(TD_WAVE_16_BOSS_UNIT_ID, 'Ocbh')
	..tdApplyEscaperStats(tdWaveBossName(16), tdWaveBossHitPoints(16), tdWaveBossArmor(16), tdWaveBossSpeed(16))
	new UnitDefinition(TD_WAVE_24_BOSS_UNIT_ID, 'Udre')
	..tdApplyEscaperStats(tdWaveBossName(24), tdWaveBossHitPoints(24), tdWaveBossArmor(24), tdWaveBossSpeed(24))
	new UnitDefinition(TD_WAVE_32_BOSS_UNIT_ID, 'Ulic')
	..tdApplyEscaperStats(tdWaveBossName(32), tdWaveBossHitPoints(32), tdWaveBossArmor(32), tdWaveBossSpeed(32))
