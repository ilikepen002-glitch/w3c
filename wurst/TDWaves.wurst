public function tdIsEliteUnitTypeId(int unitTypeId) returns boolean
	return unitTypeId == TD_WAVE_4_ELITE_UNIT_ID or unitTypeId == TD_WAVE_12_ELITE_UNIT_ID or unitTypeId == TD_WAVE_20_ELITE_UNIT_ID or unitTypeId == TD_WAVE_28_ELITE_UNIT_ID

public function tdIsBossGuardUnitTypeId(int unitTypeId) returns boolean
	return unitTypeId == TD_WAVE_8_GUARD_UNIT_ID or unitTypeId == TD_WAVE_16_GUARD_UNIT_ID or unitTypeId == TD_WAVE_24_GUARD_UNIT_ID or unitTypeId == TD_WAVE_32_GUARD_UNIT_ID

public function tdIsBossUnitTypeId(int unitTypeId) returns boolean
	return unitTypeId == TD_WAVE_8_BOSS_UNIT_ID or unitTypeId == TD_WAVE_16_BOSS_UNIT_ID or unitTypeId == TD_WAVE_24_BOSS_UNIT_ID or unitTypeId == TD_WAVE_32_BOSS_UNIT_ID

public function tdWaveSpawnUnitId(int wave, int remainingCount) returns int
	let normalCount = tdWaveNormalEnemyCount(wave)
	let guardCount = tdWaveBossGuardEnemyCount(wave)
	if tdWaveBossEnemyCount(wave) > 0 and remainingCount > normalCount + guardCount
		return tdWaveSpecialUnitId(wave)
	if guardCount > 0 and remainingCount > normalCount
		return tdWaveBossGuardUnitId(wave)
	if tdWaveEliteEnemyCount(wave) > 0 and remainingCount > normalCount
		return tdWaveSpecialUnitId(wave)
	return tdWaveUnitId(wave)

public function tdWaveSpawnInterval(int wave) returns real
	if wave <= 1
		return 1.05
	if wave <= 3
		return 0.98
	if wave <= 5
		return 0.88
	if wave <= 8
		return 0.78
	if wave <= 12
		return 0.70
	if wave <= 16
		return 0.64
	if wave <= 20
		return 0.58
	if wave <= 24
		return 0.54
	if wave <= 28
		return 0.50
	return 0.46

