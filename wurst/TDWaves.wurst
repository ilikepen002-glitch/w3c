@compiletime function tdGenerateEscaperObjects()
	new UnitDefinition(TD_WAVE_1_UNIT_ID, 'hpea')
		..tdApplyEscaperStats(tdWaveNormalName(1), tdWaveBaseHitPoints(1), tdWaveBaseArmor(1), tdWaveBaseSpeed(1))
	new UnitDefinition(TD_WAVE_2_UNIT_ID, 'hfoo')
		..tdApplyEscaperStats(tdWaveNormalName(2), tdWaveBaseHitPoints(2), tdWaveBaseArmor(2), tdWaveBaseSpeed(2))
	new UnitDefinition(TD_WAVE_3_UNIT_ID, 'ugho')
		..tdApplyEscaperStats(tdWaveNormalName(3), tdWaveBaseHitPoints(3), tdWaveBaseArmor(3), tdWaveBaseSpeed(3))
	new UnitDefinition(TD_WAVE_4_UNIT_ID, 'hrif')
		..tdApplyEscaperStats(tdWaveNormalName(4), tdWaveBaseHitPoints(4), tdWaveBaseArmor(4), tdWaveBaseSpeed(4))
	new UnitDefinition(TD_WAVE_5_UNIT_ID, 'ogru')
		..tdApplyEscaperStats(tdWaveNormalName(5), tdWaveBaseHitPoints(5), tdWaveBaseArmor(5), tdWaveBaseSpeed(5))
	new UnitDefinition(TD_WAVE_6_UNIT_ID, 'edry')
		..tdApplyEscaperStats(tdWaveNormalName(6), tdWaveBaseHitPoints(6), tdWaveBaseArmor(6), tdWaveBaseSpeed(6))
	new UnitDefinition(TD_WAVE_7_UNIT_ID, 'esen')
		..tdApplyEscaperStats(tdWaveNormalName(7), tdWaveBaseHitPoints(7), tdWaveBaseArmor(7), tdWaveBaseSpeed(7))
	new UnitDefinition(TD_WAVE_8_UNIT_ID, 'uaco')
		..tdApplyEscaperStats(tdWaveNormalName(8), tdWaveBaseHitPoints(8), tdWaveBaseArmor(8), tdWaveBaseSpeed(8))
	new UnitDefinition(TD_WAVE_9_UNIT_ID, 'okod')
		..tdApplyEscaperStats(tdWaveNormalName(9), tdWaveBaseHitPoints(9), tdWaveBaseArmor(9), tdWaveBaseSpeed(9))
	new UnitDefinition(TD_WAVE_10_UNIT_ID, 'nfel')
		..tdApplyEscaperStats(tdWaveNormalName(10), tdWaveBaseHitPoints(10), tdWaveBaseArmor(10), tdWaveBaseSpeed(10))
	new UnitDefinition(TD_WAVE_11_UNIT_ID, 'otau')
		..tdApplyEscaperStats(tdWaveNormalName(11), tdWaveBaseHitPoints(11), tdWaveBaseArmor(11), tdWaveBaseSpeed(11))
	new UnitDefinition(TD_WAVE_12_UNIT_ID, 'uabo')
		..tdApplyEscaperStats(tdWaveNormalName(12), tdWaveBaseHitPoints(12), tdWaveBaseArmor(12), tdWaveBaseSpeed(12))
	new UnitDefinition(TD_WAVE_13_UNIT_ID, 'ncen')
		..tdApplyEscaperStats(tdWaveNormalName(13), tdWaveBaseHitPoints(13), tdWaveBaseArmor(13), tdWaveBaseSpeed(13))
	new UnitDefinition(TD_WAVE_14_UNIT_ID, 'hkni')
		..tdApplyEscaperStats(tdWaveNormalName(14), tdWaveBaseHitPoints(14), tdWaveBaseArmor(14), tdWaveBaseSpeed(14))
	new UnitDefinition(TD_WAVE_15_UNIT_ID, 'nbal')
		..tdApplyEscaperStats(tdWaveNormalName(15), tdWaveBaseHitPoints(15), tdWaveBaseArmor(15), tdWaveBaseSpeed(15))
	new UnitDefinition(TD_WAVE_16_UNIT_ID, 'opeo')
		..tdApplyEscaperStats(tdWaveNormalName(16), tdWaveBaseHitPoints(16), tdWaveBaseArmor(16), tdWaveBaseSpeed(16))

	new UnitDefinition(TD_WAVE_8_ELITE_UNIT_ID, 'nfel')
		..tdApplyEscaperStats(tdWaveSpecialName(8), tdWaveEliteHitPoints(8), tdWaveEliteArmor(8), tdWaveEliteSpeed(8))
	new UnitDefinition(TD_WAVE_12_ELITE_UNIT_ID, 'nbst')
		..tdApplyEscaperStats(tdWaveSpecialName(12), tdWaveEliteHitPoints(12), tdWaveEliteArmor(12), tdWaveEliteSpeed(12))
	new UnitDefinition(TD_WAVE_15_ELITE_UNIT_ID, 'ordr')
		..tdApplyEscaperStats(tdWaveSpecialName(15), tdWaveEliteHitPoints(15), tdWaveEliteArmor(15), tdWaveEliteSpeed(15))
	new UnitDefinition(TD_WAVE_16_BOSS_UNIT_ID, 'Ocbh')
		..tdApplyEscaperStats(tdWaveSpecialName(16), tdWaveBossHitPoints(16), tdWaveBossArmor(16), tdWaveBossSpeed(16))

public function tdWaveUnitId(int wave) returns int
	if wave == 1
		return TD_WAVE_1_UNIT_ID
	if wave == 2
		return TD_WAVE_2_UNIT_ID
	if wave == 3
		return TD_WAVE_3_UNIT_ID
	if wave == 4
		return TD_WAVE_4_UNIT_ID
	if wave == 5
		return TD_WAVE_5_UNIT_ID
	if wave == 6
		return TD_WAVE_6_UNIT_ID
	if wave == 7
		return TD_WAVE_7_UNIT_ID
	if wave == 8
		return TD_WAVE_8_UNIT_ID
	if wave == 9
		return TD_WAVE_9_UNIT_ID
	if wave == 10
		return TD_WAVE_10_UNIT_ID
	if wave == 11
		return TD_WAVE_11_UNIT_ID
	if wave == 12
		return TD_WAVE_12_UNIT_ID
	if wave == 13
		return TD_WAVE_13_UNIT_ID
	if wave == 14
		return TD_WAVE_14_UNIT_ID
	if wave == 15
		return TD_WAVE_15_UNIT_ID
	return TD_WAVE_16_UNIT_ID

public function tdWaveSpecialUnitId(int wave) returns int
	if wave == 8
		return TD_WAVE_8_ELITE_UNIT_ID
	if wave == 12
		return TD_WAVE_12_ELITE_UNIT_ID
	if wave == 15
		return TD_WAVE_15_ELITE_UNIT_ID
	if wave == 16
		return TD_WAVE_16_BOSS_UNIT_ID
	return 0

public function tdWaveSpawnUnitId(int wave, int remainingCount) returns int
	if tdWaveSpecialEnemyCount(wave) > 0 and remainingCount > tdWaveNormalEnemyCount(wave)
		return tdWaveSpecialUnitId(wave)
	return tdWaveUnitId(wave)

public function tdWaveSpawnInterval(int wave) returns real
	if wave == 1
