function tdEnsureItemCatalog()
	if tdItemCatalogInitialized
		return
	tdItemCatalogInitialized = true
	tdRegisterLaunchWhiteItems()
	tdRegisterLaunchGreenItems()
	tdRegisterLaunchBlueItems()
	tdRegisterLaunchPurpleItems()

function tdItemDefinitionIndex(int itemId) returns int
	// Rawcodes collide in Jass arrays, so item metadata must be resolved through the catalog.
	for index = 1 to tdItemDefinitionTotal
		if tdItemCatalog[index] == itemId
			return index
	return 0

public function tdItemDefinitionCount() returns int
	tdEnsureItemCatalog()
	return tdItemDefinitionTotal

public function tdItemQualityCount(int quality) returns int
	tdEnsureItemCatalog()
	return tdItemQualitySizes[quality]

public function tdNextItemQuality(int quality) returns int
	if quality < TD_ITEM_QUALITY_WHITE
		return TD_ITEM_QUALITY_WHITE
	if quality >= TD_ITEM_QUALITY_PURPLE
		return TD_ITEM_QUALITY_PURPLE
	return quality + 1

public function tdItemIsEquipment(int itemId) returns boolean
	tdEnsureItemCatalog()
	return tdItemDefinitionIndex(itemId) > 0

public function tdItemName(int itemId) returns string
	tdEnsureItemCatalog()
	let definitionIndex = tdItemDefinitionIndex(itemId)
	if definitionIndex == 0
		return ""
	return tdItemNames[definitionIndex]

public function tdItemQuality(int itemId) returns int
	tdEnsureItemCatalog()
	let definitionIndex = tdItemDefinitionIndex(itemId)
	if definitionIndex == 0
		return 0
	return tdItemQualities[definitionIndex]

public function tdItemPrimaryEffectKind(int itemId) returns int
	tdEnsureItemCatalog()
	let definitionIndex = tdItemDefinitionIndex(itemId)
	if definitionIndex == 0
		return TD_ITEM_EFFECT_NONE
	return tdItemPrimaryEffectKinds[definitionIndex]

public function tdItemPrimaryEffectValue(int itemId) returns real
	tdEnsureItemCatalog()
	let definitionIndex = tdItemDefinitionIndex(itemId)
	if definitionIndex == 0
		return 0.0
	return tdItemPrimaryEffectValues[definitionIndex]

public function tdItemSecondaryEffectKind(int itemId) returns int
	tdEnsureItemCatalog()
	let definitionIndex = tdItemDefinitionIndex(itemId)
	if definitionIndex == 0
		return TD_ITEM_EFFECT_NONE
	return tdItemSecondaryEffectKinds[definitionIndex]

public function tdItemSecondaryEffectValue(int itemId) returns real
	tdEnsureItemCatalog()
	let definitionIndex = tdItemDefinitionIndex(itemId)
	if definitionIndex == 0
		return 0.0
	return tdItemSecondaryEffectValues[definitionIndex]

public function tdItemIdForCatalogIndex(int index) returns int
	tdEnsureItemCatalog()
	return tdItemCatalog[index]

public function tdItemIdForQualityRoll(int quality, int roll) returns int
	tdEnsureItemCatalog()
	let size = tdItemQualityCount(quality)
	if size <= 0
		return 0
	var clampedRoll = roll
	if clampedRoll < 1
		clampedRoll = 1
	if clampedRoll > size
		clampedRoll = size
	return tdItemQualityPools[tdItemQualityPoolKey(quality, clampedRoll)]

public function tdRandomItemIdForQuality(int quality) returns int
	tdEnsureItemCatalog()
	return tdItemIdForQualityRoll(quality, GetRandomInt(1, tdItemQualityCount(quality)))

public function tdItemQualityName(int quality) returns string
	if quality == TD_ITEM_QUALITY_WHITE
		return "白装"
	if quality == TD_ITEM_QUALITY_GREEN
		return "绿装"
	if quality == TD_ITEM_QUALITY_BLUE
		return "蓝装"
	if quality == TD_ITEM_QUALITY_PURPLE
		return "紫装"
	return "未知"

public function tdItemQualityTitleColor(int quality) returns string
	if quality == TD_ITEM_QUALITY_WHITE
		return "|cffffffff"
	if quality == TD_ITEM_QUALITY_GREEN
		return "|cff00ff00"
	if quality == TD_ITEM_QUALITY_BLUE
		return "|cff3399ff"
	if quality == TD_ITEM_QUALITY_PURPLE
		return "|cffcc66ff"
	return "|cffffffff"

public function tdItemTitleName(int itemId) returns string
	return tdItemQualityTitleColor(tdItemQuality(itemId)) + tdItemName(itemId) + "|r"

function tdItemEffectText(int effectKind, real value) returns string
	if effectKind == TD_ITEM_EFFECT_ATTACK
		return "攻击 +" + R2I(value + 0.5).toString()
	if effectKind == TD_ITEM_EFFECT_RANGE
		return "射程 +" + R2I(value + 0.5).toString()
	if effectKind == TD_ITEM_EFFECT_ATTACK_SPEED
		return "攻速 +" + R2I(value * 100.0 + 0.5).toString() + "%"
	if effectKind == TD_ITEM_EFFECT_COOLDOWN
		return "冷却缩减 " + R2I(value * 100.0 + 0.5).toString() + "%"
	if effectKind == TD_ITEM_EFFECT_KILL_GOLD
		return "击杀金币 +" + R2I(value + 0.5).toString()
	if effectKind == TD_ITEM_EFFECT_ARMOR_SHRED
		return "减甲 " + R2I(value + 0.5).toString()
	if effectKind == TD_ITEM_EFFECT_EXECUTE
		return "半血增伤 " + R2I(value * 100.0 + 0.5).toString() + "%"
	if effectKind == TD_ITEM_EFFECT_POISON
		return "毒伤 " + R2I(value + 0.5).toString() + "/秒"
	if effectKind == TD_ITEM_EFFECT_CONTROL_POWER
		return "控制强化 +" + R2I(value * 100.0 + 0.5).toString() + "%"
	if effectKind == TD_ITEM_EFFECT_DROP_BONUS
		return "掉装加权 +" + R2I(value + 0.5).toString()
	if effectKind == TD_ITEM_EFFECT_BOSS_DAMAGE
		return "Boss增伤 " + R2I(value * 100.0 + 0.5).toString() + "%"
	return ""

public function tdItemTooltip(int itemId) returns string
	tdEnsureItemCatalog()
	let primary = tdItemEffectText(tdItemPrimaryEffectKind(itemId), tdItemPrimaryEffectValue(itemId))
	let secondary = tdItemEffectText(tdItemSecondaryEffectKind(itemId), tdItemSecondaryEffectValue(itemId))
	var tooltip = tdItemQualityName(tdItemQuality(itemId)) + "装备"
	if primary != ""
		tooltip += "\n" + primary
	if secondary != ""
		tooltip += "\n" + secondary
	tooltip += "\n可给塔穿戴，也可放进工人前 3 格合成。"
	return tooltip

public function tdItemLevel(int itemId) returns int
	let quality = tdItemQuality(itemId)
	if quality == TD_ITEM_QUALITY_WHITE
		return 1
	if quality == TD_ITEM_QUALITY_GREEN
		return 3
	if quality == TD_ITEM_QUALITY_BLUE
		return 5
	if quality == TD_ITEM_QUALITY_PURPLE
		return 7
	return 1

public function tdFarmerCraftIconPath() returns string
	return Icons.bTNTransmute

public function tdItemIconPath(int itemId) returns string
	if itemId == TD_ITEM_SHORT_BOW_ID or itemId == TD_ITEM_STEEL_LONGBOW_ID or itemId == TD_ITEM_WINDRUNNER_BOW_ID or itemId == TD_ITEM_WHITE_TIGER_BANNER_ID
		return "ReplaceableTextures\\CommandButtons\\BTNArcher.blp"
	if itemId == TD_ITEM_EAGLE_SCOPE_ID or itemId == TD_ITEM_HUNTER_SCOPE_ID
		return "ReplaceableTextures\\CommandButtons\\BTNSnazzyPotion.blp"
	if itemId == TD_ITEM_SWIFT_GLOVES_ID or itemId == TD_ITEM_TOXIC_VINE_ID or itemId == TD_ITEM_CORRUPTED_HEART_ID
		return "ReplaceableTextures\\CommandButtons\\BTNGlove.blp"
	if itemId == TD_ITEM_COOLING_RUNE_ID or itemId == TD_ITEM_RHYTHM_TOTEM_ID or itemId == TD_ITEM_FROST_TOME_ID or itemId == TD_ITEM_COMMAND_SEAL_ID
		return "ReplaceableTextures\\CommandButtons\\BTNRune.blp"
	if itemId == TD_ITEM_GOLD_RING_ID or itemId == TD_ITEM_MERCENARY_PURSE_ID or itemId == TD_ITEM_BOUNTY_CONTRACT_ID
		return "ReplaceableTextures\\CommandButtons\\BTNChestOfGold.blp"
	if itemId == TD_ITEM_ARMOR_SPIKE_ID or itemId == TD_ITEM_WAR_AXE_ID or itemId == TD_ITEM_ARMOR_DRUM_ID or itemId == TD_ITEM_BLADEMASTER_SIGIL_ID
		return "ReplaceableTextures\\CommandButtons\\BTNClawsOfAttack.blp"
	if itemId == TD_ITEM_EXECUTION_DAGGER_ID or itemId == TD_ITEM_LACERATING_SPIKE_ID or itemId == TD_ITEM_EXECUTION_MARK_ID
		return "ReplaceableTextures\\CommandButtons\\BTNDaggerOfEscape.blp"
	if itemId == TD_ITEM_POISON_SAC_ID
		return "ReplaceableTextures\\CommandButtons\\BTNOrbOfVenom.blp"
	if itemId == TD_ITEM_STABLE_TOTEM_ID
		return "ReplaceableTextures\\CommandButtons\\BTNCommand.blp"
	if itemId == TD_ITEM_SCAVENGER_BAG_ID
		return "ReplaceableTextures\\CommandButtons\\BTNPackBeast.blp"
	return "ReplaceableTextures\\CommandButtons\\BTNScroll.blp"

function tdPassiveAbilityForEffect(int effectKind, real value) returns int
	if effectKind == TD_ITEM_EFFECT_ATTACK
		if value <= 8.0
			return TD_ITEM_ATTACK_BONUS_WHITE_ABILITY_ID
		if value <= 14.0
			return TD_ITEM_ATTACK_BONUS_GREEN_ABILITY_ID
		if value <= 22.0
			return TD_ITEM_ATTACK_BONUS_BLUE_ABILITY_ID
		return TD_ITEM_ATTACK_BONUS_PURPLE_ABILITY_ID
	if effectKind == TD_ITEM_EFFECT_ATTACK_SPEED
		if value <= 0.12
			return TD_ITEM_ATTACK_SPEED_WHITE_ABILITY_ID
		if value <= 0.20
			return TD_ITEM_ATTACK_SPEED_GREEN_ABILITY_ID
		if value <= 0.32
			return TD_ITEM_ATTACK_SPEED_BLUE_ABILITY_ID
		return TD_ITEM_ATTACK_SPEED_PURPLE_ABILITY_ID
	return 0

function tdAppendAbilityRawcode(string existing, int abilityId) returns string
	if abilityId == 0
		return existing
	if existing == ""
		return abilityId.toRawCode()
	return existing + "," + abilityId.toRawCode()

public function tdItemPassiveAbilityRawcodes(int itemId) returns string
	tdEnsureItemCatalog()
	var result = ""
	result = tdAppendAbilityRawcode(result, tdPassiveAbilityForEffect(tdItemPrimaryEffectKind(itemId), tdItemPrimaryEffectValue(itemId)))
	result = tdAppendAbilityRawcode(result, tdPassiveAbilityForEffect(tdItemSecondaryEffectKind(itemId), tdItemSecondaryEffectValue(itemId)))
	return result
