constant int TD_ITEM_POOL_STRIDE = 32
boolean tdItemCatalogInitialized = false
int tdItemDefinitionTotal = 0
int array tdItemCatalog
int array tdItemQualitySizes
int array tdItemQualityPools
string array tdItemNames
int array tdItemQualities
int array tdItemPrimaryEffectKinds
real array tdItemPrimaryEffectValues
int array tdItemSecondaryEffectKinds
real array tdItemSecondaryEffectValues

function tdItemQualityPoolKey(int quality, int index) returns int
	return quality * TD_ITEM_POOL_STRIDE + index

function tdRegisterItem(int itemId, int quality, string name, int primaryKind, real primaryValue, int secondaryKind, real secondaryValue)
	tdItemDefinitionTotal += 1
	let definitionIndex = tdItemDefinitionTotal
	tdItemCatalog[definitionIndex] = itemId
	tdItemNames[definitionIndex] = name
	tdItemQualities[definitionIndex] = quality
	tdItemPrimaryEffectKinds[definitionIndex] = primaryKind
	tdItemPrimaryEffectValues[definitionIndex] = primaryValue
	tdItemSecondaryEffectKinds[definitionIndex] = secondaryKind
	tdItemSecondaryEffectValues[definitionIndex] = secondaryValue
	tdItemQualitySizes[quality] += 1
	tdItemQualityPools[tdItemQualityPoolKey(quality, tdItemQualitySizes[quality])] = itemId

