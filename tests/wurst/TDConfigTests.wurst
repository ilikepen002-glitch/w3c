package TDConfigTests
import TDConfig
import TerrainUtils

@Test function startingValuesArePositive()
	TD_STARTING_LIVES.assertGreaterThan(0)
	TD_STARTING_GOLD.assertEquals(100)
	TD_FIRST_WAVE_DELAY.assertEquals(30.0)
	TD_TIME_BETWEEN_WAVES.assertEquals(20.0)

@Test function balanceMultipliersDefaultToNeutralValues()
	tdEnemyHealthMultiplier().assertEquals(1.0)
	tdEnemyArmorMultiplier().assertEquals(1.0)
	tdEnemySpeedMultiplier().assertEquals(1.0)
	tdEconomyMultiplier().assertEquals(1.0)

@Test function activePlayerCountIsFour()
	TD_ACTIVE_PLAYER_COUNT.assertEquals(4)

@Test function towerChoiceCountIsThree()
	TD_TOWER_CHOICE_COUNT.assertEquals(5)

@Test function builderAndPlotMarkersUseCustomObjects()
	(TD_FARMER_UNIT_ID != 'hpea').assertTrue()
	(TD_BUILD_PLOT_UNIT_ID != 'hhou').assertTrue()

@Test function eachLaneKeepsEnoughGrassBuildSpace()
	TD_BUILD_PLOTS_PER_LANE.assertGreaterThanOrEqual(10)
	(tdBuildPlotPosition(0, 0).y != tdBuildPlotPosition(0, 1).y).assertTrue()
	(tdBuildPlotPosition(0, 9).x > tdBuildPlotPosition(0, 0).x).assertTrue()

@Test function buildPlotsSnapToStableTileCenters()
	for playerId = 0 to TD_ACTIVE_PLAYER_COUNT - 1
		for plotIndex = 0 to TD_BUILD_PLOTS_PER_LANE - 1
			tdBuildPlotCenter(playerId, plotIndex).assertEquals(tdBuildPlotPosition(playerId, plotIndex).toTileCenter())

@Test function buildPlotsStaySeparatedByAtLeastOneBuildCell()
	for playerId = 0 to TD_ACTIVE_PLAYER_COUNT - 1
		for leftIndex = 0 to TD_BUILD_PLOTS_PER_LANE - 1
			for rightIndex = leftIndex + 1 to TD_BUILD_PLOTS_PER_LANE - 1
				let leftPlot = tdBuildPlotCenter(playerId, leftIndex)
				let rightPlot = tdBuildPlotCenter(playerId, rightIndex)
				(leftPlot.distanceTo(rightPlot) >= tdBuildPlotMinimumSpacing()).assertTrue()

@Test function exactBuildPlotCentersResolveBackToTheirOwnSlot()
	for playerId = 0 to TD_ACTIVE_PLAYER_COUNT - 1
		for plotIndex = 0 to TD_BUILD_PLOTS_PER_LANE - 1
			tdFindBuildPlotIndex(playerId, tdBuildPlotCenter(playerId, plotIndex)).assertEquals(plotIndex)

@Test function offLanePositionsDoNotResolveToAnyBuildPlot()
	tdFindBuildPlotIndex(0, tdLaneExitPosition(0)).assertEquals(-1)

@Test function laneEndpointsExposeStableStartAndEndPositions()
	(tdLaneSpawnPosition(0).distanceTo(tdLaneExitPosition(0)) > 0.).assertTrue()
	(tdLaneSpawnPosition(1).distanceTo(tdLaneExitPosition(1)) > 0.).assertTrue()
	(tdLaneSpawnPosition(2).distanceTo(tdLaneExitPosition(2)) > 0.).assertTrue()
	(tdLaneSpawnPosition(3).distanceTo(tdLaneExitPosition(3)) > 0.).assertTrue()

@Test function playerOneUsesFiveWaypointStepsBeforeCenterExit()
	tdLaneWaypointCount(0).assertEquals(5)
	tdLaneWaypointCount(1).assertEquals(0)
	tdLaneWaypointPosition(0, 0).distanceTo(tdLaneSpawnPosition(0)).assertGreaterThan(0.)
	tdLaneWaypointPosition(0, 4).distanceTo(tdLaneExitPosition(0)).assertGreaterThan(0.)

@Test function playerOneWaypointPositionsComeFromWorldEditorRegions()
	R2I(tdLaneWaypointPosition(0, 0).x).assertEquals(-1168)
	R2I(tdLaneWaypointPosition(0, 0).y).assertEquals(2672)
	R2I(tdLaneWaypointPosition(0, 1).x).assertEquals(-1168)
	R2I(tdLaneWaypointPosition(0, 1).y).assertEquals(1424)
	R2I(tdLaneWaypointPosition(0, 2).x).assertEquals(-2800)
	R2I(tdLaneWaypointPosition(0, 2).y).assertEquals(1392)
	R2I(tdLaneWaypointPosition(0, 3).x).assertEquals(-2800)
	R2I(tdLaneWaypointPosition(0, 3).y).assertEquals(400)
	R2I(tdLaneWaypointPosition(0, 4).x).assertEquals(-1168)
	R2I(tdLaneWaypointPosition(0, 4).y).assertEquals(336)

@Test function buildZonesStayScopedToEachPlayerLane()
	tdLaneBuildZoneRadius().assertGreaterThanOrEqual(128.0)
	tdIsInLaneBuildZone(0, tdBuildPlotCenter(0, 0)).assertTrue()
	tdIsInLaneBuildZone(0, tdBuildPlotCenter(1, 0)).assertFalse()
	tdIsInLaneBuildZone(2, tdBuildPlotCenter(2, 9)).assertTrue()
	tdIsInLaneBuildZone(2, tdBuildPlotCenter(0, 0)).assertFalse()

@Test function allLanesMergeIntoSharedCenterExit()
	let exit0 = tdLaneExitPosition(0)
	let exit1 = tdLaneExitPosition(1)
	let exit2 = tdLaneExitPosition(2)
	let exit3 = tdLaneExitPosition(3)
	exit0.x.assertEquals(exit1.x)
	exit0.y.assertEquals(exit1.y)
	exit0.x.assertEquals(exit2.x)
	exit0.y.assertEquals(exit2.y)
	exit0.x.assertEquals(exit3.x)
	exit0.y.assertEquals(exit3.y)

@Test function staticRegionAnchorsDriveLaneEndpoints()
	R2I(tdLaneSpawnPosition(0).x).assertEquals(-2320)
	R2I(tdLaneSpawnPosition(0).y).assertEquals(2672)
	R2I(tdLaneSpawnPosition(1).x).assertEquals(2448)
	R2I(tdLaneSpawnPosition(1).y).assertEquals(2704)
	R2I(tdLaneSpawnPosition(2).x).assertEquals(2352)
	R2I(tdLaneSpawnPosition(2).y).assertEquals(-3056)
	R2I(tdLaneSpawnPosition(3).x).assertEquals(-2320)
	R2I(tdLaneSpawnPosition(3).y).assertEquals(-3056)
	R2I(tdFarmerSpawnPosition(0).x).assertEquals(-1616)
	R2I(tdFarmerSpawnPosition(0).y).assertEquals(2064)
	R2I(tdFarmerSpawnPosition(3).x).assertEquals(-1936)
	R2I(tdFarmerSpawnPosition(3).y).assertEquals(-2384)
	R2I(tdLaneExitPosition(0).x).assertEquals(-16)
	R2I(tdLaneExitPosition(0).y).assertEquals(-192)
	(tdLaneSpawnPosition(0).distanceTo(tdLaneExitPosition(0)) > 0.).assertTrue()
	(tdLaneSpawnPosition(1).distanceTo(tdLaneExitPosition(1)) > 0.).assertTrue()
