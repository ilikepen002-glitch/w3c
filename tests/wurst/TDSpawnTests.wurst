package TDSpawnTests
import TDSpawn
import TDWaves
import Orders

@Test function spawnedEnemiesDoNotUseCreepGuard()
	tdEnemyUsesCreepGuard().assertEquals(false)
	tdEnemyRemovesGuardPositionForTest().assertEquals(true)
	tdEnemyRuntimePathingEnabledForTest().assertEquals(true)
	tdEnemyWaypointArrivalRadiusForTest().assertGreaterThanOrEqual(150.0)
	tdEnemySleepsAtNight().assertEquals(false)
	tdEnemyNativeGoldBountyBase().assertEquals(0)
	tdEnemyNativeGoldBountyDice().assertEquals(0)
	tdEnemyNativeGoldBountySides().assertEquals(0)
	tdEnemyLaneOrderNameForTest().assertEquals("move")
	tdEnemyLaneOrderIdForTest().assertEquals(Orders.move)
	tdEnemyNeedsLaneOrderRefreshForTest(Orders.move, Orders.move).assertEquals(false)
	tdEnemyNeedsLaneOrderRefreshForTest(Orders.patrol, Orders.move).assertTrue()
	tdEnemyShouldIssueLaneOrderForTest(Orders.move, Orders.move, false).assertEquals(false)
	tdEnemyShouldIssueLaneOrderForTest(Orders.move, Orders.move, true).assertTrue()

@Test function enemyHealthDisplayIsNotManagedByRuntime()
	tdEnemyHealthDisplayManagedByRuntimeForTest().assertFalse()
