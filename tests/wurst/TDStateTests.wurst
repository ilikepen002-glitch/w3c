package TDStateTests
import TDState
import TDConfig

@Test function resetRestoresDefaultsForEveryPlayer()
	tdResetState()
	tdGetGlobalWave().assertEquals(0)
	tdGetTowerPopulationLimit().assertEquals(4)
	tdGetUnlockedPopulationStage().assertEquals(1)
	for i = 0 to TD_ACTIVE_PLAYER_COUNT - 1
		tdGetLives(i).assertEquals(TD_STARTING_LIVES)
		tdGetGold(i).assertEquals(TD_STARTING_GOLD)
		tdGetCurrentWave(i).assertEquals(0)
	tdGetTeamScore().assertEquals(0)

@Test function spendGoldReducesOnlyOnePlayersBalance()
	tdResetState()
	tdSpendGold(1, 50)
	tdGetGold(1).assertEquals(TD_STARTING_GOLD - 50)
	tdGetGold(0).assertEquals(TD_STARTING_GOLD)

@Test function losingLifeReducesOnlyOnePlayersLives()
	tdResetState()
	tdLoseLife(2, 2)
	tdGetLives(2).assertEquals(TD_STARTING_LIVES - 2)
	tdGetLives(0).assertEquals(TD_STARTING_LIVES)

@Test function addingLaneScoreAlsoUpdatesTeamScore()
	tdResetState()
	tdAddScore(3, 25)
	tdGetLaneScore(3).assertEquals(25)
	tdGetTeamScore().assertEquals(25)

@Test function laneActivityTracksOpenAndClosedLanes()
	tdResetState()
	tdCountActiveLanes().assertEquals(0)
	tdIsLaneActive(0).assertFalse()
	tdSetLaneActive(0, true)
	tdSetLaneActive(2, true)
	tdIsLaneActive(0).assertTrue()
	tdIsLaneActive(1).assertFalse()
	tdIsLaneActive(2).assertTrue()
	tdCountActiveLanes().assertEquals(2)

@Test function globalWaveStateIsTrackedSeparately()
	tdResetState()
	tdSetGlobalWave(3)
	tdGetGlobalWave().assertEquals(3)
	tdSetCurrentWave(0, tdGetGlobalWave())
	tdGetCurrentWave(0).assertEquals(3)

@Test function nextWaveQueueResetsWithState()
	tdResetState()
	tdQueueNextWave(4)
	tdIsNextWaveQueued().assertTrue()
	tdGetQueuedWave().assertEquals(4)
	tdResetState()
	tdIsNextWaveQueued().assertFalse()
	tdGetQueuedWave().assertEquals(0)

@Test function nextWaveWaitsForAllContinuingLanesToResolve()
	tdResetState()
	tdSetLaneActive(0, true)
	tdSetLaneActive(1, true)
	tdSetResolvedWave(0, 3)
	tdAllContinuingLanesResolved(3).assertFalse()
	tdSetResolvedWave(1, 3)
	tdAllContinuingLanesResolved(3).assertTrue()

@Test function defeatedLanesDoNotBlockNextWaveReadiness()
	tdResetState()
	tdSetLaneActive(0, true)
	tdSetLaneActive(1, true)
	tdSetLaneDefeated(1, true)
	tdSetResolvedWave(0, 5)
	tdAllContinuingLanesResolved(5).assertTrue()

@Test function waveResolutionTracksSpecificWavesBeforeContiguousProgress()
	tdResetState()
	tdSetLaneActive(0, true)
	tdMarkWaveResolved(0, 2)
	tdIsWaveResolved(0, 2).assertTrue()
	tdGetResolvedWave(0).assertEquals(0)
	tdAllContinuingLanesResolved(1).assertFalse()
	tdAllContinuingLanesResolved(2).assertTrue()
	tdMarkWaveResolved(0, 1)
	tdGetResolvedWave(0).assertEquals(2)

@Test function laneWaveDropBudgetStateResetsWithMatchState()
	tdResetState()
	tdGetLaneWaveDropCount(1, 8).assertEquals(0)
	tdMarkLaneWaveDrop(1, 8)
	tdMarkLaneWaveDrop(1, 8)
	tdGetLaneWaveDropCount(1, 8).assertEquals(2)
	tdResetState()
	tdGetLaneWaveDropCount(1, 8).assertEquals(0)

@Test function waveThirtyTwoCanBeMarkedResolved()
	tdResetState()
	tdSetLaneActive(0, true)
	tdMarkWaveResolved(0, 32)
	tdIsWaveResolved(0, 32).assertTrue()
	tdAllContinuingLanesResolved(32).assertTrue()

@Test function populationLimitUnlocksByCompletedBossStage()
	tdResetState()
	tdPopulationLimitForStage(1).assertEquals(4)
	tdPopulationLimitForStage(2).assertEquals(6)
	tdPopulationLimitForStage(3).assertEquals(8)
	tdPopulationLimitForStage(4).assertEquals(10)
	tdUnlockPopulationForCompletedWave(7).assertFalse()
	tdGetTowerPopulationLimit().assertEquals(4)
	tdUnlockPopulationForCompletedWave(8).assertTrue()
	tdGetTowerPopulationLimit().assertEquals(6)
	tdGetUnlockedPopulationStage().assertEquals(2)
	tdUnlockPopulationForCompletedWave(8).assertFalse()
	tdGetTowerPopulationLimit().assertEquals(6)
	tdUnlockPopulationForCompletedWave(16).assertTrue()
	tdGetTowerPopulationLimit().assertEquals(8)
	tdUnlockPopulationForCompletedWave(24).assertTrue()
	tdGetTowerPopulationLimit().assertEquals(10)
	tdUnlockPopulationForCompletedWave(32).assertFalse()
	tdGetTowerPopulationLimit().assertEquals(10)
