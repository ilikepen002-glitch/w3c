package TDInventoryTests
import TDInventory
import TDItems
import TDConfig
import TDTowers

@Test function towersKeepThreeSlotsAndThirdDuplicateIsPenalized()
	tdTowerEquipmentSlotCount().assertEquals(3)
	tdTowerEquipmentDuplicateFactor(1).assertEquals(1.0)
	tdTowerEquipmentDuplicateFactor(2).assertEquals(1.0)
	tdTowerEquipmentDuplicateFactor(3).assertEquals(0.5)
	tdEquipmentAttackBonusForItems(TD_ITEM_SHORT_BOW_ID, TD_ITEM_SHORT_BOW_ID, TD_ITEM_SHORT_BOW_ID).assertEquals(20.0)
	tdTowerAttackBonusAbilityLevelForItems(TD_ITEM_SHORT_BOW_ID, TD_ITEM_SHORT_BOW_ID, TD_ITEM_SHORT_BOW_ID).assertEquals(20)

@Test function cooldownAndRangeBonusesRespectCaps()
	tdTowerEquipmentCooldownCap().assertEquals(0.40)
	tdTowerEquipmentRangeCap().assertEquals(500.0)
	tdEquipmentCooldownReductionForItems(TD_ITEM_COOLING_RUNE_ID, TD_ITEM_COOLING_RUNE_ID, TD_ITEM_COOLING_RUNE_ID).assertEquals(0.20)
	tdEquipmentRangeBonusForItems(TD_ITEM_EAGLE_SCOPE_ID, TD_ITEM_EAGLE_SCOPE_ID, TD_ITEM_EAGLE_SCOPE_ID).assertEquals(225.0)
	tdEquipmentRangeBonusForItems(TD_ITEM_WHITE_TIGER_BANNER_ID, TD_ITEM_WHITE_TIGER_BANNER_ID, TD_ITEM_WHITE_TIGER_BANNER_ID).assertEquals(500.0)
	tdTowerAttackSpeedAbilityLevelForItems(TD_ITEM_SWIFT_GLOVES_ID, TD_ITEM_SWIFT_GLOVES_ID, TD_ITEM_SWIFT_GLOVES_ID).assertEquals(30)

@Test function economicAndDropBonusesAggregatePerTower()
	tdEquipmentKillGoldBonusForItems(TD_ITEM_GOLD_RING_ID, TD_ITEM_MERCENARY_PURSE_ID, 0).assertEquals(3)
	tdEquipmentDropBonusRollsForItems(TD_ITEM_SCAVENGER_BAG_ID, TD_ITEM_MERCENARY_PURSE_ID, 0).assertEquals(2)

@Test function distinctRawcodesDoNotShareDuplicatePenaltyBuckets()
	tdEquipmentAttackBonusForItems(TD_ITEM_SHORT_BOW_ID, TD_ITEM_STEEL_LONGBOW_ID, TD_ITEM_WHITE_TIGER_BANNER_ID).assertEquals(56.0)

@Test function towerEffectiveRangeAddsEquipmentBonusOnTopOfBaseRange()
	let baseRange = tdTowerBaseRangeForBranch(TD_TOWER_CHOICE_ARCHER, 5, TD_TOWER_BRANCH_A).toReal()
	tdTowerEffectiveRangeForLoadout(TD_TOWER_CHOICE_ARCHER, 5, TD_TOWER_BRANCH_A, TD_ITEM_EAGLE_SCOPE_ID, TD_ITEM_FOCUS_STONE_ID, 0).assertEquals(baseRange + 240.0)
