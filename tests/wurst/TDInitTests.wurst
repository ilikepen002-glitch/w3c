package TDInitTests
import TDInit
import TDState
import TDConfig

@Test function startupWaitsBrieflyBeforeRuntimeBootstrap()
	tdMapBootstrapDelay().assertGreaterThan(0.0)
	tdMapBootstrapDelay().assertEquals(0.10)

@Test function startupRetryPolicyAllowsLatePlayerSlotActivation()
	tdMapBootstrapRetryInterval().assertEquals(0.25)
	tdMapBootstrapMaxRetries().assertEquals(8)

@Test function startupFallbackActivatesPlayerOneWhenNoLaneWasDetected()
	tdResetState()
	tdEnsureStartupFallbackLane()
	tdIsLaneActive(0).assertTrue()
	tdCountActiveLanes().assertEquals(1)

@Test function startupRevealsTheWholeMap()
	tdShouldRevealWholeMap().assertTrue()

@Test function startupGuideTextUsesChinese()
	tdStartupGuideMessage().contains("建塔").assertTrue()
	tdStartupGuideMessage().contains("白色坑道").assertFalse()
	tdStartupGuideMessage().contains("起点").assertTrue()
	tdStartupGuideMessage().contains("终点").assertTrue()
	tdStartupGuideMessage().contains("滚轮").assertTrue()
	tdStartupGuideMessage().contains("Static map mode").assertFalse()

@Test function startupCameraStartsHigherAndAllowsThreeExtraWheelHeights()
	tdDefaultCameraTargetDistance().assertEquals(3200.0)
	tdDefaultCameraAngleOfAttack().assertEquals(338.0)
	tdCameraWheelLiftStepCount().assertEquals(3)
	tdCameraWheelLiftDistancePerStep().assertEquals(400.0)
	tdStartingCameraReapplyDelay().assertEquals(0.10)
	tdCameraDistanceClampInterval().assertEquals(0.15)
	tdCameraTargetDistanceMin().assertEquals(3200.0)
	tdCameraTargetDistanceMax().assertEquals(4400.0)
	tdCameraTargetDistanceForWheelLift(0).assertEquals(3200.0)
	tdCameraTargetDistanceForWheelLift(3).assertEquals(4400.0)
	tdClampCameraTargetDistance(2000.0).assertEquals(3200.0)
	tdClampCameraTargetDistance(5000.0).assertEquals(4400.0)

@Test function startupFocusesCameraOnThePlayersFarmer()
	tdShouldFocusStartingCameraOnFarmer().assertTrue()
	tdShouldSelectStartingFarmer().assertFalse()

@Test function closedPlayersAreOnlyMentionedInOneStartupNotice()
	tdInactiveLaneNoticeForTest(true, false, false, true).assertEquals("未开启玩家：2、3。本局只启动已进入游戏的路线。")
	tdInactiveLaneNoticeForTest(true, true, true, true).assertEquals("")

@Test function addMoneyCommandGivesGoldToTheTriggeringPlayer()
	tdResetState()
	tdTryHandleAddMoneyCommand(0, "-addMoney 1000").assertTrue()
	tdGetGold(0).assertEquals(TD_STARTING_GOLD + 1000)
	tdGetGold(1).assertEquals(TD_STARTING_GOLD)

@Test function addMoneyCommandRejectsInvalidAmounts()
	tdResetState()
	tdTryHandleAddMoneyCommand(0, "-addMoney nope").assertFalse()
	tdGetGold(0).assertEquals(TD_STARTING_GOLD)
