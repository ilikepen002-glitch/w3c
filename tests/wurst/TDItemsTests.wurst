package TDItemsTests
import TDItems

@Test function launchCatalogKeepsExpectedQualitySpread()
	tdItemDefinitionCount().assertEquals(28)
	tdItemQualityCount(TD_ITEM_QUALITY_WHITE).assertEquals(10)
	tdItemQualityCount(TD_ITEM_QUALITY_GREEN).assertEquals(8)
	tdItemQualityCount(TD_ITEM_QUALITY_BLUE).assertEquals(6)
	tdItemQualityCount(TD_ITEM_QUALITY_PURPLE).assertEquals(4)

@Test function qualityProgressionStopsAtPurple()
	tdNextItemQuality(TD_ITEM_QUALITY_WHITE).assertEquals(TD_ITEM_QUALITY_GREEN)
	tdNextItemQuality(TD_ITEM_QUALITY_GREEN).assertEquals(TD_ITEM_QUALITY_BLUE)
	tdNextItemQuality(TD_ITEM_QUALITY_BLUE).assertEquals(TD_ITEM_QUALITY_PURPLE)
	tdNextItemQuality(TD_ITEM_QUALITY_PURPLE).assertEquals(TD_ITEM_QUALITY_PURPLE)

@Test function launchWhiteAndBlueItemsExposeStableMetadata()
	tdItemIsEquipment(TD_ITEM_SHORT_BOW_ID).assertTrue()
	tdItemName(TD_ITEM_SHORT_BOW_ID).assertEquals("短弓")
	tdItemQuality(TD_ITEM_SHORT_BOW_ID).assertEquals(TD_ITEM_QUALITY_WHITE)
	tdItemPrimaryEffectKind(TD_ITEM_SHORT_BOW_ID).assertEquals(TD_ITEM_EFFECT_ATTACK)
	tdItemPrimaryEffectValue(TD_ITEM_SHORT_BOW_ID).assertEquals(8.0)
	tdItemName(TD_ITEM_BOUNTY_CONTRACT_ID).assertEquals("赏金契约")
	tdItemQuality(TD_ITEM_BOUNTY_CONTRACT_ID).assertEquals(TD_ITEM_QUALITY_BLUE)

@Test function equipmentTitleNamesUseQualityColorsWithoutChangingPlainNames()
	tdItemName(TD_ITEM_BOUNTY_CONTRACT_ID).assertEquals("赏金契约")
	tdItemTitleName(TD_ITEM_SHORT_BOW_ID).assertEquals("|cffffffff短弓|r")
	tdItemTitleName(TD_ITEM_STEEL_LONGBOW_ID).assertEquals("|cff00ff00精钢长弓|r")
	tdItemTitleName(TD_ITEM_BOUNTY_CONTRACT_ID).assertEquals("|cff3399ff赏金契约|r")
	tdItemTitleName(TD_ITEM_WHITE_TIGER_BANNER_ID).assertEquals("|cffcc66ff白虎战旗|r")

@Test function farmerCraftUsesDistinctTransmuteIcon()
	tdFarmerCraftIconPath().assertEquals("ReplaceableTextures\\CommandButtons\\BTNTransmute.blp")
